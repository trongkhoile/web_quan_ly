generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String       @id @default(cuid())
  email     String       @unique
  password  String
  name      String
  isAdmin   Boolean      @default(false)
  accounts  Mt5Account[]
  createdAt DateTime     @default(now())
}

model Mt5Account {
  id           String         @id @default(cuid())
  userId       String?
  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  mt5Login     String
  mt5Password  String
  mt5Server    String
  terminalPath String?
  isActive     Boolean        @default(true)
  status       String         @default("connected")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  trades       TradeHistory[]

  @@unique([mt5Login, mt5Server])
}

model TradeLog {
  id        String   @id @default(cuid())
  signal    String
  status    String
  result    String?
  createdAt DateTime @default(now())
}

model TradeHistory {
  id         String     @id @default(cuid())
  accountId  String
  account    Mt5Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol     String
  type       String
  lot        Float
  openPrice  Float
  closePrice Float
  profit     Float
  openTime   DateTime
  closeTime  DateTime
  createdAt  DateTime   @default(now())
}
